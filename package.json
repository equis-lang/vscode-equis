{
    "name": "vscode-equis",
    "displayName": "Equis",
    "description": "Equis language support with native LSP.",
    "version": "0.1.0",
    "publisher": "equis-lang",
    "repository": {
        "type": "git",
        "url": "https://github.com/equis-lang/vscode-equis.git"
    },
    "icon": "logo.png",
    "engines": {
        "vscode": "^1.50.0"
    },
    "activationEvents": [
        "onLanguage:equis"
    ],
    "main": "./dist/extension.js",
    "contributes": {
        "languages": [
            {
                "id": "equis",
                "aliases": [
                    "Equis",
                    "equis"
                ],
                "extensions": [
                    ".equis"
                ],
                "configuration": "./language-configuration.json",
                "icon": {
                    "light": "./logo.svg",
                    "dark": "./logo.svg"
                }
            }
        ],
        "grammars": [
            {
                "language": "equis",
                "scopeName": "source.equis",
                "path": "./equis.tmLanguage.json"
            }
        ],
        "iconThemes": [
            {
                "id": "equis-icons",
                "label": "Equis",
                "path": "./equis-icons.json"
            }
        ],
        "configuration": {
            "type": "object",
            "title": "Equis",
            "properties": {
                "equis.executablePath": {
                    "type": "string",
                    "default": "",
                    "description": "Absolute path to the Equis executable (e.g. /home/user/.equis/bin/eq). Leave empty to use PATH."
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./"
    },
    "dependencies": {
        "vscode-languageclient": "^7.0.0"
    },
    "devDependencies": {
        "@types/node": "^12.11.7",
        "@types/vscode": "^1.50.0",
        "typescript": "^4.0.2"
    }
}